# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
PREFIX=!

# ── LLM ────────────────────────────────────────────────────────────────────────
LLAMA_API_URL=http://127.0.0.1:8080
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.8
# Keep this short — it gets read aloud
SYSTEM_PROMPT=You are a helpful voice assistant in a Discord server. Keep responses concise and conversational. Avoid markdown.

# ── STT ────────────────────────────────────────────────────────────────────────
# Options: tiny, base, small, medium
# "small" is the sweet spot: ~500MB RAM, good accuracy
WHISPER_MODEL=small
# Options: pywhispercpp, cli
WHISPER_BACKEND=pywhispercpp
# Only needed if WHISPER_BACKEND=cli
WHISPER_CLI_PATH=whisper-cli

# ── TTS ────────────────────────────────────────────────────────────────────────
# Options: kokoro, piper
TTS_ENGINE=kokoro

# Kokoro voices: af_heart, af_bella, am_adam, am_michael, bf_emma, bm_george
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0

# Piper (only used if TTS_ENGINE=piper)
PIPER_MODEL=en_US-lessac-medium.onnx
PIPER_CLI_PATH=piper

# ── Audio tuning ───────────────────────────────────────────────────────────────
# Raise SILENCE_THRESHOLD if the bot triggers on background noise
# Lower it if it misses quiet speakers
SILENCE_THRESHOLD=500
SILENCE_DURATION=1.5
